#!/usr/bin/env bash
# Fast gate (headless, no game DLLs): Core logic tests + architecture rules. Keep it quick so it is
# never bypassed; the full audit runs on pre-push.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
echo "[pre-commit] Core logic tests..."
dotnet test "$root/tests/Core/Nucleus.Domain.Tests.csproj" -c Release --nologo --verbosity quiet
echo "[pre-commit] architecture rules..."
dotnet test "$root/tests/Nucleus.Architecture.Tests/Nucleus.Architecture.Tests.csproj" -c Release --nologo --verbosity quiet
echo "[pre-commit] OK"
