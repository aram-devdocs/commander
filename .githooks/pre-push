#!/usr/bin/env bash
# Full gate, mirroring CI: scripts/check.sh builds the solution with warnings-as-errors and runs Core +
# architecture rules, plus the game-contract tests when the proprietary game DLL is present.
set -euo pipefail
root="$(git rev-parse --show-toplevel)"
echo "[pre-push] full check..."
bash "$root/scripts/check.sh"
echo "[pre-push] OK"
